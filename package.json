{
  "name": "visa-lark",
  "version": "0.1.0",
  "private": true,
  "description": "VisaLark (签证云雀) — open-source US visa appointment monitor + assisted booking. Residential-IP, zero-credential, zero-evasion.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build && pnpm -r --filter \"./apps/*\" build",
    "build:packages": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rimraf dist node_modules .turbo || true"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
