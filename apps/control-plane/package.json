{
  "name": "@visa-lark/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "VisaLark optional self-host control plane: notification relay + availability history + heatmap. Holds ZERO visa credentials, never touches usvisa-info.",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@visa-lark/notify": "workspace:*",
    "@visa-lark/shared": "workspace:*",
    "better-sqlite3": "^12.2.0",
    "fastify": "^5.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
