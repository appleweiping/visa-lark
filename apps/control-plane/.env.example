# VisaLark control-plane configuration (single-tenant, self-host).
# Copy to .env and fill in. NEVER commit your real .env.
#
# This plane holds ZERO visa credentials and never talks to usvisa-info.
# It only relays notifications and stores availability history you push to it.

# Port the server listens on (default 8787).
PORT=8787

# REQUIRED. A single bearer token that guards every /api route except /api/health.
# Generate a strong one, e.g.:  openssl rand -hex 32
# Until this is set, all protected routes return 503 (fail-closed, never an open relay).
DASHBOARD_TOKEN=change-me-to-a-long-random-string

# SQLite database file path. Relative paths resolve under the app root.
# The directory is created automatically.
DB_PATH=./data/visalark.db

# CORS: the origin of your deployed web app (apps/web on Vercel), comma-separated.
# Use * only for local testing.
FRONTEND_ORIGIN=https://your-visalark.vercel.app
